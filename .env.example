# ──────────────────────────────────────────────────────────────
# Morfeus Website — variabili d'ambiente
# Copia in `.env.local` per lo sviluppo. In produzione: impostale su Vercel.
# Verifica completezza: `node scripts/check-env.mjs` (--strict per fallire)
# ──────────────────────────────────────────────────────────────

# ── Brevo (email/lead) — REQUIRED per gli optin ──
# Si usa V2 se presente, altrimenti il fallback. Almeno una delle due è obbligatoria.
BREVO_API_KEY_V2=
BREVO_API_KEY=

# ── Brevo: ID lista per funnel (numerici, dalla dashboard Brevo) ──
# Mapping canonico: src/lib/brevo/lists.ts — vedi docs/brevo.md
BREVO_WEBINAR_LIST_ID=                      # 54 — Webinar Claude 5 mag
BREVO_FREEBIE_SKILL_LIST_ID=                # 56 — Freebie Cowork Setup Skill
BREVO_FREEBIE_INSTAGRAM_CAROUSEL_LIST_ID=   # 57 — Freebie Instagram Carousel
BREVO_FREEBIE_DESIGN_SYSTEM_LIST_ID=        # 61 — Freebie Design System Blueprint
BREVO_NEXT_WEBINAR_LIST_ID=                 # 62 — Iscritti prossimo webinar
BREVO_PLAYBOOK_INFOBIZ_LIST_ID=            # 63 — Playbook Infobiz
BREVO_FORMAZIONE_FINANZIATA_LIST_ID=        # 64 — Candidature AI Zero to Operator
BREVO_FREEBIE_AI_FUNDAMENTALS_LIST_ID=      # 65 — Freebie AI Fundamentals

# ── Tracking (OPTIONAL) ──
NEXT_PUBLIC_META_PIXEL_ID=                  # Meta Pixel (Facebook) — sui funnel
